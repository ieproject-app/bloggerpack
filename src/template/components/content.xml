<bp:template>
  <main class='main-content' id='mainContent'>
    <b:section class='main-section' id='main-section' maxwidgets='1' name='Main' showaddelement='no'>
      <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' visible='true'>

        <b:includable id='main' var='this'>

          <b:if cond='data:view.isMultipleItems'>

            <b:if cond='data:view.isLabelSearch'>
              <div class='page-header'>
                <p class='page-header__kicker'>Category</p>
                <h1 class='page-header__title'>
                  <data:view.search.label.name/>
                </h1>
              </div>
            </b:if>

            <b:if cond='data:view.search.query'>
              <div class='page-header'>
                <p class='page-header__kicker'>Search results for</p>
                <h1 class='page-header__title'>
                  &#8220;<data:view.search.query/>&#8221;
                </h1>
              </div>
            </b:if>

            <b:if cond='data:view.isArchive'>
              <div class='page-header'>
                <p class='page-header__kicker'>Archive</p>
              </div>
            </b:if>

            <b:if cond='data:posts.notEmpty'>
              <b:if cond='data:view.isHomepage'>
                <b:loop values='data:posts' var='post' index='i'>
                  <b:if cond='data:i == 0'>
                    <b:include data='post' name='featured-post'/>
                  </b:if>
                </b:loop>
                <div class='post-grid'>
                  <b:loop values='data:posts' var='post' index='i'>
                    <b:if cond='data:i != 0'>
                      <b:include data='post' name='post-card'/>
                    </b:if>
                  </b:loop>
                </div>
              <b:else/>
                <div class='post-grid'>
                  <b:loop values='data:posts' var='post'>
                    <b:include data='post' name='post-card'/>
                  </b:loop>
                </div>
              </b:if>
            <b:else/>
              <p class='no-posts'>No posts found.</p>
            </b:if>

            <b:include name='pager'/>

          <b:elseif cond='data:view.isPage'/>

            <b:loop values='data:posts' var='post'>
              <article class='post-page' expr:id='"post-" + data:post.id'>
                <header class='post-page__header'>
                  <h1 class='post-page__title'>
                    <b:eval expr='data:post.title ? data:post.title : data:messages.noTitle'/>
                  </h1>
                </header>
                <div class='post-page__body'>
                  <data:post.body/>
                </div>
              </article>
            </b:loop>

          <b:else/>

            <b:loop values='data:posts' var='post'>
              <b:include data='post' name='post-page'/>
            </b:loop>

          </b:if>

        </b:includable>

        <b:includable id='featured-post' var='post'>
          <article class='featured-post' expr:id='"post-" + data:post.id'>
            <b:if cond='data:post.featuredImage'>
              <a class='featured-post__thumb' expr:href='data:post.url'>
                <img
                  decoding='async'
                  expr:alt='data:post.title'
                  expr:src='data:post.featuredImage'
                  height='630'
                  loading='eager'
                  width='1200'
                />
              </a>
            </b:if>
            <div class='featured-post__body'>
              <b:if cond='data:post.labels'>
                <div class='featured-post__labels'>
                  <b:loop values='data:post.labels' var='label'>
                    <a class='post-card__label' expr:href='data:label.url'>
                      <data:label.name/>
                    </a>
                  </b:loop>
                </div>
              </b:if>
              <h2 class='featured-post__title'>
                <a expr:href='data:post.url'>
                  <b:eval expr='data:post.title ? data:post.title : data:messages.noTitle'/>
                </a>
              </h2>
              <b:if cond='data:post.snippet'>
                <p class='featured-post__excerpt'>
                  <data:post.snippet/>
                </p>
              </b:if>
              <div class='featured-post__meta'>
                <span class='post-meta__author'>
                  <svg aria-hidden='true' fill='none' height='13' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' viewBox='0 0 24 24' width='13' xmlns='http://www.w3.org/2000/svg'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>
                  <data:post.author.name/>
                </span>
                <time class='post-meta__date' expr:datetime='data:post.date.iso8601'>
                  <data:post.date/>
                </time>
              </div>
              <a class='btn btn--primary featured-post__cta' expr:href='data:post.url'>
                Read article
                <svg aria-hidden='true' fill='none' height='16' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' viewBox='0 0 24 24' width='16' xmlns='http://www.w3.org/2000/svg'><line x1='5' x2='19' y1='12' y2='12'/><polyline points='12 5 19 12 12 19'/></svg>
              </a>
            </div>
          </article>
        </b:includable>

        <b:includable id='post-card' var='post'>
          <article class='post-card' expr:id='"post-" + data:post.id'>

            <b:if cond='data:post.featuredImage'>
              <a class='post-card__thumb' expr:href='data:post.link ?: data:post.url'>
                <img
                  decoding='async'
                  expr:alt='data:post.title'
                  expr:src='data:post.featuredImage'
                  height='450'
                  loading='lazy'
                  width='800'
                />
              </a>
            </b:if>

            <div class='post-card__body'>

              <b:if cond='data:post.labels'>
                <div class='post-card__labels'>
                  <b:loop values='data:post.labels' var='label'>
                    <a class='post-card__label' expr:href='data:label.url'>
                      <data:label.name/>
                    </a>
                  </b:loop>
                </div>
              </b:if>

              <h2 class='post-card__title'>
                <a expr:href='data:post.link ?: data:post.url'>
                  <b:eval expr='data:post.title ? data:post.title : data:messages.noTitle'/>
                </a>
              </h2>

              <b:if cond='data:post.snippet'>
                <p class='post-card__excerpt'>
                  <data:post.snippet/>
                </p>
              </b:if>

              <div class='post-card__meta'>
                <span class='post-meta__author'>
                  <svg aria-hidden='true' fill='none' height='12' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' viewBox='0 0 24 24' width='12' xmlns='http://www.w3.org/2000/svg'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>
                  <data:post.author.name/>
                </span>
                <time class='post-meta__date' expr:datetime='data:post.date.iso8601'>
                  <data:post.date/>
                </time>
              </div>

            </div>
          </article>
        </b:includable>

        <b:includable id='post-page' var='post'>
          <article class='post-page' expr:id='"post-" + data:post.id'>

            <header class='post-page__header'>

              <b:if cond='data:post.labels'>
                <div class='post-page__labels'>
                  <b:loop values='data:post.labels' var='label'>
                    <a class='post-page__label' expr:href='data:label.url'>
                      <data:label.name/>
                    </a>
                  </b:loop>
                </div>
              </b:if>

              <h1 class='post-page__title'>
                <b:eval expr='data:post.title ? data:post.title : data:messages.noTitle'/>
              </h1>

              <div class='post-page__meta'>
                <span class='post-meta__author'>
                  <svg aria-hidden='true' fill='none' height='13' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' viewBox='0 0 24 24' width='13' xmlns='http://www.w3.org/2000/svg'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/></svg>
                  <data:post.author.name/>
                </span>
                <time class='post-meta__date' expr:datetime='data:post.date.iso8601'>
                  <data:post.date/>
                </time>
              </div>

              <b:if cond='data:post.featuredImage'>
                <div class='post-page__thumb'>
                  <img
                    decoding='async'
                    expr:alt='data:post.title'
                    expr:src='data:post.featuredImage'
                    height='630'
                    loading='eager'
                    width='1200'
                  />
                </div>
              </b:if>

            </header>

            <div class='post-page__body'>
              <data:post.body/>
            </div>

            <footer class='post-page__footer'>

              <b:if cond='data:post.labels'>
                <div class='post-page__tags'>
                  <span class='post-page__tags-label'>Tags:</span>
                  <b:loop values='data:post.labels' var='label'>
                    <a class='post-page__tag' expr:href='data:label.url'>
                      <data:label.name/>
                    </a>
                  </b:loop>
                </div>
              </b:if>

              <b:if cond='data:post.allowComments'>
                <div class='post-comments' id='comments'>
                  <b:include data='post' name='comments'/>
                </div>
              </b:if>

            </footer>

          </article>
        </b:includable>

        <b:includable id='comments' var='post'>
          <div class='comments'>
            <h3 class='comments__title'>
              <b:if cond='data:post.commentNumber == 1'>
                1 <data:messages.comment/>
              <b:else/>
                <data:post.commentNumber/> <data:messages.comments/>
              </b:if>
            </h3>
            <div class='comments__iframe'>
              <b:include data='post' name='addComments'/>
            </div>
          </div>
        </b:includable>

        <b:includable id='pager'>
          <b:if cond='data:newerPageUrl or data:olderPageUrl'>
            <nav aria-label='Pagination' class='pagination'>
              <a class='pagination__btn pagination__btn--prev'>
                <b:attr expr:value='data:newerPageUrl ? data:newerPageUrl : "#"' name='href'/>
                <b:class cond='!data:newerPageUrl' name='is-disabled'/>
                <svg aria-hidden='true' fill='none' height='16' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' viewBox='0 0 24 24' width='16' xmlns='http://www.w3.org/2000/svg'><polyline points='15 18 9 12 15 6'/></svg>
                <data:messages.newer/>
              </a>

              <a class='pagination__home' expr:href='data:blog.homepageUrl'>
                <data:messages.home/>
              </a>

              <a class='pagination__btn pagination__btn--next'>
                <b:attr expr:value='data:olderPageUrl ? data:olderPageUrl : "#"' name='href'/>
                <b:class cond='!data:olderPageUrl' name='is-disabled'/>
                <data:messages.older/>
                <svg aria-hidden='true' fill='none' height='16' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' viewBox='0 0 24 24' width='16' xmlns='http://www.w3.org/2000/svg'><polyline points='9 18 15 12 9 6'/></svg>
              </a>
            </nav>
          </b:if>
        </b:includable>

        {# Remove non-comment default includables (comments restored to Blogger default) #}
        <b:includable id='aboutPostAuthor'/>
        <b:includable id='feedLinks'/>
        <b:includable id='feedLinksBody'/>
        <b:includable id='homePageLink'/>
        <b:includable id='inlineAd'/>
        <b:includable id='nextPageLink'/>
        <b:includable id='post'/>
        <b:includable id='postBody'/>
        <b:includable id='postBodySnippet'/>
        <b:includable id='postCommentsAndAd'/>
        <b:includable id='postCommentsLink'/>
        <b:includable id='postFooter'/>
        <b:includable id='postFooterAuthorProfile'/>
        <b:includable id='postHeader'/>
        <b:includable id='postMeta'/>
        <b:includable id='postPagination'/>
        <b:includable id='postTitle'/>
        <b:includable id='previousPageLink'/>

      </b:widget>
    </b:section>
  </main>
</bp:template>
