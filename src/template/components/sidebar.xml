<bp:template>
  <aside class='sidebar' id='sidebar'>

    <b:section class='sidebar-section' id='sidebar-section' name='Sidebar' showaddelement='yes'>

      <b:widget id='Profile1' locked='false' title='About Me' type='Profile' version='2' visible='true'>
        <b:includable id='main'>
          <div class='widget widget--profile'>
            <b:if cond='data:title'>
              <h3 class='widget__title'>
                <data:title/>
              </h3>
            </b:if>
            <div class='widget-profile__card'>
              <b:if cond='data:photo.url'>
                <div class='widget-profile__avatar'>
                  <img expr:alt='data:authorName' expr:src='data:photo.url' height='64' loading='lazy' width='64'/>
                </div>
              </b:if>
              <div class='widget-profile__info'>
                <p class='widget-profile__name'>
                  <data:authorName/>
                </p>
                <b:if cond='data:aboutMe'>
                  <p class='widget-profile__bio'>
                    <data:aboutMe/>
                  </p>
                </b:if>
              </div>
            </div>
          </div>
        </b:includable>
      </b:widget>

      <b:widget id='PopularPosts1' locked='false' title='Popular Posts' type='PopularPosts' version='2' visible='true'>
        <b:includable id='main'>
          <div class='widget'>
            <b:if cond='data:title'>
              <h3 class='widget__title'>
                <data:title/>
              </h3>
            </b:if>
            <div class='widget--popular-posts'>
              <b:loop values='data:posts' var='post'>
                <div class='popular-post'>
                  <b:if cond='data:post.thumbnail'>
                    <a class='popular-post__thumb' expr:href='data:post.url'>
                      <img decoding='async' expr:alt='data:post.title' expr:src='data:post.thumbnail' height='60' loading='lazy' width='60'/>
                    </a>
                  </b:if>
                  <div class='popular-post__info'>
                    <a class='popular-post__title' expr:href='data:post.url'>
                      <data:post.title/>
                    </a>
                    <time class='popular-post__date' expr:datetime='data:post.date.iso8601'>
                      <data:post.date/>
                    </time>
                  </div>
                </div>
              </b:loop>
            </div>
          </div>
        </b:includable>
      </b:widget>

      <b:widget id='Label1' locked='false' title='Topics' type='Label' version='2' visible='true'>
        <b:includable id='main'>
          <div class='widget'>
            <b:if cond='data:title'>
              <h3 class='widget__title'>
                <data:title/>
              </h3>
            </b:if>
            <div class='widget--labels'>
              <b:loop values='data:labels' var='label'>
                <a class='label-tag' expr:href='data:label.url'>
                  <data:label.name/>
                  <span class='label-tag__count'>
                    <data:label.count/>
                  </span>
                </a>
              </b:loop>
            </div>
          </div>
        </b:includable>
      </b:widget>

    </b:section>

  </aside>
</bp:template>
